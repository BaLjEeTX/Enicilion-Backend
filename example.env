PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enicilion
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
CLIENT_URL=http://localhost:3000
UPLOAD_DIR=/app/uploads

# PayPal (Legacy / Alternative)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# PayU (Legacy / Alternative)
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt
PAYU_BASE_URL=https://secure.payu.in/_payment

# Razorpay API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_SANDBOX_BYPASS_ALLOWED=false

# Cashfree API Keys
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=production

# Scanner Security
SCANNER_PASSWORD=your_scanner_password

# Email Settings (for sending tickets)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tickets@enicilion.com
SMTP_PASS=your_smtp_pass
FROM_EMAIL=tickets@enicilion.com
FROM_NAME="Enicilion Motorscape"

# Event Details (Used in the ticket email)
EVENT_NAME="Enicilion Motorscape"
EVENT_DATE="May 30, 2026"
EVENT_LOCATION="Chandigarh (To Be Announced)"
BASE_URL="http://localhost:4000"

# Firebase Real-Time sync
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account_json

# Other integrations
WASENDER_API_KEY=your_wasender_api_key
BREVO_API_KEY=your_brevo_api_key
OPS_PANEL_KEY=your_ops_panel_key
META_CAPI_TOKEN=your_meta_capi_token
META_PIXEL_ID=your_meta_pixel_id
AISENSY_API_KEY=your_aisensy_api_key

# ZeptoMail configurations
ZEPTOMAIL_TOKEN=your_zeptomail_token
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTOMAIL_API_KEY=your_zeptomail_api_key_same_as_token
ZEPTOMAIL_SENDER=noreply@enicilion.com

# Ops Panel Security keys
OPS_KEY_SUPER=your_ops_key_super
OPS_KEY_MANAGER=your_ops_key_manager
OPS_KEY_SCANNER=your_ops_key_scanner

# Snap Pixel
SNAP_PIXEL_ID=your_snap_pixel_id
SNAP_CAPI_TOKEN=your_snap_capi_token

# WhatsApp — Meta Cloud API
WA_TOKEN=your_wa_token
WA_PHONE_NUMBER_ID=your_wa_phone_number_id
WA_TEMPLATE_NAME=enc_ticket_confirmed_v3
WA_VERIFY_TOKEN=your_wa_verify_token

# Public API Base URL
PUBLIC_API_BASE_URL=http://localhost:4000/api
